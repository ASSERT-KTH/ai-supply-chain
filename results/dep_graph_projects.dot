      "repo:huggingface/datasets" [label="datasets\nLOC: 79k | deps: 41", shape=box, fillcolor="#8c6bb1", fontcolor=white];
      "repo:huggingface/peft" [label="peft\nLOC: 264k | deps: 55", shape=box, fillcolor="#8c6bb1", fontcolor=white];
