      "repo:huggingface/huggingface_hub" [label="huggingface_hub\nLOC: 103k | deps: 21", shape=box, fillcolor="#8c6bb1", fontcolor=white];
      "repo:huggingface/transformers" [label="transformers\nLOC: 1.2M | deps: 26", shape=box, fillcolor="#8c6bb1", fontcolor=white];
    }
    subgraph cluster_integration_serving {
